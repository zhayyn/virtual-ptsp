{
    "name": "virtual-ptsp/core",
    "type": "project",
    "description": "Virtual PTSP - Omnichannel Customer Service Platform with AI",
    "keywords": [
        "omnichannel",
        "customer-service",
        "whatsapp",
        "chatbot",
        "ai",
        "knowledge-base"
    ],
    "license": "proprietary",
    "authors": [
        {
            "name": "zhayyn",
            "email": "+6281317361689",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.12",
        "guzzlehttp/guzzle": "^7.8",
        "predis/predis": "^2.2",
        "laravelpwa/server": "^0.6.0",
        "symfony/yaml": "^7.0",
        "openai-php/laravel": "^0.9.0",
        "anthropic/sdk": "^0.28.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.15",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/attack": "^2.0",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
