# ============================================================
# Virtual PTSP - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# Built with ❤️ by zhayyn (+6281317361689)
# ============================================================

# ============================================================
# Application
# ============================================================
APP_NAME="Virtual PTSP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# ============================================================
# Server Configuration
# ============================================================
APP_PORT=80
APP_SSL_PORT=443
DB_PORT=3306
REDIS_PORT=6379
LICENSE_PORT=8080

# ============================================================
# Database
# ============================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=virtual_ptsp
DB_USERNAME=virtual_ptsp
DB_PASSWORD=

# MySQL Root (for migrations)
MYSQL_ROOT_PASSWORD=

# ============================================================
# Redis Cache
# ============================================================
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_CLIENT=predis

# ============================================================
# Session & Queue
# ============================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ============================================================
# Mail Configuration
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@virtual-ptsp.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# Google OAuth (Buyer Configures This Themselves)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ============================================================
# AI Providers (Buyer Configures This Themselves)
# ============================================================
# Default AI Provider (gemini, claude, openai)
DEFAULT_AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# ============================================================
# WhatsApp Gateway (Buyer Configures This)
# ============================================================
# Example: WaCaraka runtime or other WA gateway
WA_GATEWAY_URL=
WA_GATEWAY_API_KEY=
WA_WEBHOOK_SECRET=

# ============================================================
# License Server Configuration
# ============================================================
# Your license server URL (where buyers validate their license)
LICENSE_SERVER_URL=https://license.virtual-ptsp.com
LICENSE_SERVER_SECRET=your_license_secret_here

# ============================================================
# Logging
# ============================================================
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_STACK=true

# ============================================================
# AWS S3 (Optional - for media storage)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# Security
# ============================================================
AUTH_SECRET=
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# ============================================================
